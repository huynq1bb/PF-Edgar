{% comment %}
  App block: Virtual Try-On + Size Predict.
  Merchant có thể thêm block này vào section (product page) và bật/tắt từng widget.
{% endcomment %}

<div class="app-block-wrapper" data-app-block>
  {% comment %} Virtual Try-On section {% endcomment %}
  <div class="virtual-try-on-block" data-virtual-try-on>
    <div class="virtual-try-on-block__header">
      <h3 class="virtual-try-on-block__title">{{ block.settings.heading | default: 'Thử trang phục' }}</h3>
      {% if block.settings.subheading != blank %}
        <p class="virtual-try-on-block__subheading">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="virtual-try-on-block__cta">
      <button type="button" class="virtual-try-on-block__button" data-try-on-trigger>
        {{ block.settings.button_label | default: 'Bắt đầu thử đồ' }}
      </button>
    </div>
    <div class="virtual-try-on-block__placeholder" data-try-on-placeholder aria-hidden="true">
      <p>{{ 'virtual_try_on.placeholder' | t }}</p>
    </div>
  </div>

  {% comment %} Size Predict widget {% endcomment %}
  {% if block.settings.show_size_predict %}
    <div class="size-predict-block app-block__size-predict" data-size-predict>
      <div class="size-predict-block__header">
        <h3 class="size-predict-block__title">{{ block.settings.size_predict_heading | default: 'Gợi ý size' }}</h3>
        {% if block.settings.size_predict_subheading != blank %}
          <p class="size-predict-block__subheading">{{ block.settings.size_predict_subheading }}</p>
        {% endif %}
      </div>
      <form class="size-predict-block__form" data-size-predict-form novalidate>
        <div class="size-predict-block__fields">
          <label class="size-predict-block__label">
            <span>{{ 'size_predict.height_label' | t: default: 'Chiều cao (cm)' }}</span>
            <input type="number" name="height" min="50" max="250" step="1" placeholder="170" required class="size-predict-block__input" data-size-predict-height />
          </label>
          <label class="size-predict-block__label">
            <span>{{ 'size_predict.weight_label' | t: default: 'Cân nặng (kg)' }}</span>
            <input type="number" name="weight" min="30" max="200" step="0.5" placeholder="65" required class="size-predict-block__input" data-size-predict-weight />
          </label>
        </div>
        <button type="submit" class="size-predict-block__button" data-size-predict-submit>
          {{ block.settings.size_predict_button_label | default: 'Gợi ý size' }}
        </button>
      </form>
      <div class="size-predict-block__result" data-size-predict-result aria-live="polite" aria-hidden="true">
        <p class="size-predict-block__message" data-size-predict-message></p>
      </div>
      <div class="size-predict-block__error" data-size-predict-error aria-live="polite" aria-hidden="true">
        <p class="size-predict-block__error-text" data-size-predict-error-text></p>
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Virtual Try-On",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "stylesheet": "app-block.css",
  "javascript": "app-block.js",
  "settings": [
    {
      "type": "header",
      "content": "Virtual Try-On"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Tiêu đề",
      "default": "Thử trang phục"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Mô tả ngắn"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Nhãn nút",
      "default": "Bắt đầu thử đồ"
    },
    {
      "type": "header",
      "content": "Gợi ý size (Size Predict)"
    },
    {
      "type": "checkbox",
      "id": "show_size_predict",
      "label": "Hiển thị widget gợi ý size",
      "default": true
    },
    {
      "type": "text",
      "id": "size_predict_heading",
      "label": "Tiêu đề gợi ý size",
      "default": "Gợi ý size"
    },
    {
      "type": "textarea",
      "id": "size_predict_subheading",
      "label": "Mô tả gợi ý size"
    },
    {
      "type": "text",
      "id": "size_predict_button_label",
      "label": "Nhãn nút gợi ý size",
      "default": "Gợi ý size"
    }
  ]
}
{% endschema %}
